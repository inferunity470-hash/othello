# Bid Othello — environment variable template.
# Copy this to `.env` (or `.env.local`) and adjust as needed. Vite reads
# variables prefixed with `VITE_` and embeds them at build time.

# WebSocket endpoint for the online multiplayer server.
# Local development (npm run start spawns server/index.ts on :8787):
#   VITE_WS_URL=ws://localhost:8787
# Production (Fly.io, Render, etc.) — use wss:// for HTTPS sites:
#   VITE_WS_URL=wss://bid-othello-ws.fly.dev
VITE_WS_URL=ws://localhost:8787

# Feature flag: show or hide the Online tab in the lobby.
# - 'true'  : tab is shown.
# - 'false' : tab is hidden (use this in production until WS hosting is live).
# - unset   : tab is shown automatically in dev builds and hidden in prod.
VITE_ONLINE_ENABLED=true
